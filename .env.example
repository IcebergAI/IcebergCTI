# Iceberg configuration. Copy to `.env` and adjust. All vars use the ICEBERG_ prefix.

# Core
ICEBERG_ENVIRONMENT=dev
# Use a random 32+ byte value in production (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`)
ICEBERG_SECRET_KEY=dev-insecure-change-me-0123456789abcdef
ICEBERG_DATABASE_URL=sqlite:///./iceberg.db
# Run `alembic upgrade head` automatically on boot (convenient for dev). Set
# false in production and run migrations explicitly in the deploy step.
ICEBERG_AUTO_MIGRATE=true

# Dev login bypass (disabled automatically when ENVIRONMENT is prod/production)
ICEBERG_DEV_AUTH=true
ICEBERG_DEV_USER_EMAIL=analyst@example.com
ICEBERG_DEV_USER_NAME=Dev Analyst
ICEBERG_DEV_USER_ROLE=ANALYST

# Microsoft Entra ID (OIDC). Set ICEBERG_OIDC_ENABLED=true and fill in to use SSO.
ICEBERG_OIDC_ENABLED=false
ICEBERG_OIDC_TENANT_ID=
ICEBERG_OIDC_CLIENT_ID=
ICEBERG_OIDC_CLIENT_SECRET=
ICEBERG_OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
# Entra app-role / group claim that carries the user's role(s)
ICEBERG_OIDC_ROLE_CLAIM=roles

# Typst rendering
ICEBERG_TYPST_BIN=typst
ICEBERG_RENDER_OUTPUT_DIR=./rendered
ICEBERG_CMARKER_VERSION=0.1.1

# Notebook attachments (uploaded reference files)
ICEBERG_ATTACHMENTS_DIR=./attachments
ICEBERG_ATTACHMENT_MAX_MB=25
# Comma-separated MIME whitelist (override to change accepted types).
# Default allows pdf, common images (no svg), text/markdown/csv and MS Office docs.
# ICEBERG_ATTACHMENT_ALLOWED_TYPES=application/pdf,image/png,image/jpeg

# Notebook figures (PNG/JPEG/GIF images embedded inline into reports via the
# [[figure:ID]] token). Stored on disk like attachments; smaller default cap
# since the bytes are base64-inlined into the report HTML.
ICEBERG_FIGURES_DIR=./figures
ICEBERG_FIGURE_MAX_MB=10

# Dissemination
ICEBERG_PORTAL_BASE_URL=http://localhost:8000
# Auto-disseminate reports at or below this TLP (RED / AMBER_STRICT withheld)
ICEBERG_DISSEMINATION_MAX_TLP=AMBER
# Email backend: console (dev, in-memory outbox) or smtp
ICEBERG_EMAIL_BACKEND=console
ICEBERG_EMAIL_FROM=iceberg@example.com
ICEBERG_SMTP_HOST=localhost
ICEBERG_SMTP_PORT=25
ICEBERG_SMTP_USER=
ICEBERG_SMTP_PASSWORD=
ICEBERG_SMTP_STARTTLS=false

# Source reliability grading
# Default is local heuristic-only. To opt into LLM grading, set provider to
# openai, anthropic, or openai_compatible and provide the model/key below.
ICEBERG_SOURCE_GRADER_PROVIDER=heuristic
ICEBERG_SOURCE_GRADER_MODEL=
ICEBERG_SOURCE_GRADER_API_KEY=
# For openai_compatible providers, set a base URL like https://api.example.com/v1
ICEBERG_SOURCE_GRADER_BASE_URL=
ICEBERG_SOURCE_GRADER_FALLBACK=heuristic
